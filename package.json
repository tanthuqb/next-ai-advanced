{
  "name": "next-ai-advanced",
  "version": "1.0.0",
  "description": "Nextjs kit AI",
  "homepage": "https://github.com/tanthuqb/next-ai-advanced#readme",
  "bugs": {
    "url": "https://github.com/tanthuqb/next-ai-advanced/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanthuqb/next-ai-advanced.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:with-embeddings": "npm run embeddings && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "embeddings": "tsx lib/generate-embeddings.ts",
    "embeddings:refresh": "tsx lib/generate-embeddings.ts --refresh",
    "functions": "supabase functions serve Embedding --no-verify-jwt --env-file ./supabase/functions/.env.secrets"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "endOfLine": "lf",
    "sqlKeywordCase": "lower"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/react": "^3.0.148",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.101.1",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.146",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "common-tags": "^1.8.2",
    "github-slugger": "^2.0.0",
    "gpt3-tokenizer": "^1.1.5",
    "lucide-react": "^1.7.0",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "micromark-extension-mdxjs": "^3.0.0",
    "next": "^16.2.2",
    "openai": "^6.33.0",
    "openai-edge": "^1.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
