    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.35",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.4.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
