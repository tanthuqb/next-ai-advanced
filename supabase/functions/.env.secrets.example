# Supabase Edge Function secrets template
# Use with:
# supabase functions serve Embedding --no-verify-jwt --env-file ./supabase/functions/.env.secrets
# supabase secrets set --env-file ./supabase/functions/.env.secrets

EDGE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EDGE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_key

# Optional
# GEMINI_API_KEY=your_google_ai_key
