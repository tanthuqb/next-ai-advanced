# Next.js app environment variables (local + Vercel)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI provider key used in app/api/chat/route.ts
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_key

# Optional for legacy scripts
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx